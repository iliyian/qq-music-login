QQ_UIN=你的QQ号
QQ_PASSWORD=你的QQ密码
VERCEL_TOKEN=你的Vercel API Token
VERCEL_PROJECT_ID=你的Vercel项目ID

# 可选：Telegram 通知（不配置则跳过通知）
TELEGRAM_BOT_TOKEN=你的Telegram Bot Token
TELEGRAM_CHAT_ID=你的Telegram Chat ID

# 可选：代理（不配置则直连）
# QQ_MUSIC_PROXY: 浏览器访问QQ音乐使用的代理
# TELEGRAM_PROXY: 发送Telegram通知使用的代理
# VERCEL_PROXY: 访问Vercel API使用的代理
QQ_MUSIC_PROXY=http://127.0.0.1:7890
TELEGRAM_PROXY=http://127.0.0.1:7890
VERCEL_PROXY=http://127.0.0.1:7890
